// Vector scale kernel - multiply all elements by a scalar

#include <hip/hip_runtime.h>

extern "C" __global__ void vector_scale(float* data, float scale, int n) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx < n) {
        data[idx] *= scale;
    }
}

